# Mnemox .env.template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Supabase ──
# Settings → API → Project URL
SUPABASE_URL=YOUR_SUPABASE_URL_HERE

# Settings → API → anon public key
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Settings → API → service_role key (keep secret!)
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY_HERE

# Settings → API → JWT Secret
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET_HERE

# ── AI ──
# platform.openai.com → API keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# cloud.qdrant.io → your cluster URL
QDRANT_URL=YOUR_QDRANT_URL_HERE

# cloud.qdrant.io → API Keys
QDRANT_API_KEY=YOUR_QDRANT_API_KEY_HERE

# ── Stripe ──
# stripe.com → Developers → API keys → Secret key (sk_live_...)
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE

# stripe.com → Developers → API keys → Publishable key (pk_live_...)
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# stripe.com → Developers → Webhooks → your endpoint → Signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE

# Product price IDs from Stripe dashboard
STRIPE_PRO_PRICE_ID=YOUR_PRO_PRICE_ID_HERE
STRIPE_TEAM_PRICE_ID=YOUR_TEAM_PRICE_ID_HERE

# ── Deploy ──
# Your Railway backend URL
BACKEND_URL=https://mnemox-production.up.railway.app

# railway.app → Account → Tokens → Create token
RAILWAY_TOKEN=YOUR_RAILWAY_TOKEN_HERE
