# ============================================================
# MNEMOX Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)
# ============================================================

# Supabase — get from https://supabase.com > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# OpenAI — for text-embedding-3-small (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here

# Qdrant vector DB — get from https://cloud.qdrant.io (free tier, no credit card)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here

# API Security — generate: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change-me-generate-a-random-secret

# App settings
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=chrome-extension://YOUR_EXTENSION_ID,http://localhost:3000
